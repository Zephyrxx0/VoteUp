# ============================================================
# VoteUp — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit real keys. This file contains ONLY placeholders.
# ============================================================

# Firebase Admin SDK (Server-side ONLY — NEVER commit real values)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Client (Public — these are safe to expose in NEXT_PUBLIC_ vars)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro-latest

# Google APIs (Server-side — keep these secret)
YOUTUBE_API_KEY=your-youtube-api-key
GOOGLE_TRANSLATE_API_KEY=your-translate-api-key
GOOGLE_MAPS_API_KEY=your-maps-api-key

# Calendar OAuth (Public — client ID is safe to expose)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com

# FCM (Public)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key

# Backend URL
NEXT_PUBLIC_API_URL=http://localhost:3001
